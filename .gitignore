# =============================================================================
# Emon DSL Skeleton —— .gitignore
# =============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
dist/
*.egg
.venv/
venv/

# ---- ANTLR4 generated files (grammar directory) ----
# Generated by: antlr4 EmonLexer.g4 EmonParser.g4
# Compiled by:  javac -cp antlr-*.jar *.java
emon-dsl/grammar/*.java
emon-dsl/grammar/*.class
emon-dsl/grammar/*.tokens
emon-dsl/grammar/*.interp

# ---- C/C++ build artifacts ----
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.o
*.obj
*.so
*.a
*.exe
*.out

# ---- IDE / Editor ----
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- OS ----
.directory
